import tkinter as tk
from tkinter import filedialog
from PyPDF2 import PdfReader
import os

# Hide tkinter window
root = tk.Tk()
root.withdraw()

# Open file dialog
file_path = filedialog.askopenfilename(
    title="Select TXT or PDF File",
    filetypes=[
        ("Text Files", "*.txt"),
        ("PDF Files", "*.pdf")
    ]
)

if not file_path:
    print("No file selected.")
    exit()

search_word = input("Enter word to search: ").lower()

extension = os.path.splitext(file_path)[1].lower()

found = False


# ---------------- TXT ---------------- #

if extension == ".txt":

    with open(file_path, "r", encoding="utf-8") as file:

        for line_number, line in enumerate(file, start=1):

            if search_word in line.lower():

                print(f"\nFound on Line {line_number}")
                print(line.strip())
                found = True


# ---------------- PDF ---------------- #

elif extension == ".pdf":

    reader = PdfReader(file_path)

    for page_number, page in enumerate(reader.pages, start=1):

        text = page.extract_text()

        if text and search_word in text.lower():

            print(f"\nFound on Page {page_number}")

            lines = text.split("\n")

            for line in lines:
                if search_word in line.lower():
                    print(line)

            found = True

else:
    print("Unsupported file type.")


if not found:
    print("\nWord not found!")
